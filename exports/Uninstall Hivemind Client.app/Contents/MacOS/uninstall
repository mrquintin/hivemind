#!/bin/bash
# =============================================================================
# Uninstall Hivemind Client
# =============================================================================
set -e

APP_NAME="Hivemind Client"
PKG_ID="com.thenashlab.hivemind.client"
APP_PATH="/Applications/${APP_NAME}.app"
PKG_UNINSTALLER="/Applications/Uninstall ${APP_NAME}.app"

# Check if the app is installed
if [ ! -d "$APP_PATH" ] && [ ! -d "$PKG_UNINSTALLER" ]; then
    osascript -e "display alert \"Uninstall ${APP_NAME}\" message \"${APP_NAME} does not appear to be installed.\" as informational"
    exit 0
fi

# Ask for confirmation
CONFIRM=$(osascript -e "display dialog \"Are you sure you want to uninstall ${APP_NAME}?

This will remove the app and all its data from this computer.\" buttons {\"Cancel\", \"Uninstall\"} default button \"Cancel\" with icon caution with title \"Uninstall ${APP_NAME}\"" 2>/dev/null) || exit 0

if [[ "$CONFIRM" != *"Uninstall"* ]]; then
    exit 0
fi

CMDS=""

# Kill running instances
pkill -f "$APP_NAME" 2>/dev/null || true
sleep 1

# Remove the main app
if [ -d "$APP_PATH" ]; then
    CMDS="rm -rf '$APP_PATH'"
fi

# Remove the PKG-installed uninstaller (if different from us)
if [ -d "$PKG_UNINSTALLER" ]; then
    CMDS="${CMDS:+$CMDS; }rm -rf '$PKG_UNINSTALLER'"
fi

# Clean up data directory: ~/Library/WebKit/com.thenashlab.hivemind.client
DATA_PATH="$(eval echo \"~/Library/WebKit/com.thenashlab.hivemind.client\")"
if [ -d "$DATA_PATH" ]; then
    CMDS="${CMDS:+$CMDS; }rm -rf '$DATA_PATH'"
fi

if [ -z "$CMDS" ]; then
    osascript -e "display alert \"Uninstall ${APP_NAME}\" message \"Nothing to remove.\" as informational"
    exit 0
fi

# Run removal with admin privileges
osascript -e "do shell script \"$CMDS\" with administrator privileges" 2>/dev/null || {
    osascript -e "display alert \"Uninstall ${APP_NAME}\" message \"Uninstallation was cancelled or failed.\" as warning"
    exit 1
}

# Forget the package receipt
osascript -e "do shell script \"pkgutil --forget $PKG_ID 2>/dev/null || true\" with administrator privileges" 2>/dev/null || true

# Remove ourselves (the standalone uninstaller) — best-effort
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
if [[ "$SELF_DIR" == *"Uninstall ${APP_NAME}.app" ]] || [[ "$SELF_DIR" == *"exports"* ]]; then
    rm -rf "$SELF_DIR" 2>/dev/null || true
fi

osascript -e "display alert \"Uninstall Complete\" message \"${APP_NAME} has been removed from this computer.\" as informational"
