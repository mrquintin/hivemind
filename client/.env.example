# =============================================================================
# HIVEMIND CLIENT APP - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and configure for your setup.
# =============================================================================

# -----------------------------------------------------------------------------
# API Server URL
# -----------------------------------------------------------------------------

# URL of the Hivemind Cloud server
# For AWS / hosted deployment:
#   VITE_API_URL=https://api.yourdomain.com
#
# The Client app connects to this URL to run analyses.

VITE_API_URL=https://api.yourdomain.com
