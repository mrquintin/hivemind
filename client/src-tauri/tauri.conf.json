{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hivemind Client",
  "version": "0.1.0",
  "identifier": "com.thenashlab.hivemind.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hivemind Client",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http: https: ws: wss:; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "AI-powered strategic analysis for executives.",
    "longDescription": "Hivemind Client runs multi-agent strategic analyses with audit trails and feasibility scoring.",
    "category": "Productivity"
  }
}
