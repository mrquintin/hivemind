# =============================================================================
# HIVEMIND CLOUD SERVER - AWS / CONTAINER ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env for containerized server usage, or use
# deploy/aws/.env.example -> deploy/aws/.env.aws for the full EC2 deployment flow.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: API Keys
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# IMPORTANT: Replace with a random string (e.g. run: openssl rand -hex 32)
# Leaving this as the default is a security risk in production.
JWT_SECRET=change-me-to-a-random-secret-string
# Optional but recommended: dedicated secret for API-key encryption at rest.
# If unset, JWT_SECRET is used as fallback.
HIVEMIND_ENCRYPTION_SECRET=
JWT_EXPIRES_MINUTES=60

# Default user passwords (used when seeding the database for the first time).
# Change these before your first deployment. After the first run, users are
# stored in the database and these env vars are only used if the users table
# is empty (e.g. after a fresh database).
DEFAULT_ADMIN_PASSWORD=hivemind-admin-2024
DEFAULT_CLIENT_PASSWORD=hivemind-client-2024

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Amazon RDS PostgreSQL connection string
# Format: postgresql+psycopg2://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql+psycopg2://hivemind:replace-with-password@your-rds-endpoint:5432/hivemind?sslmode=require

# Qdrant URL used by the app container
VECTOR_DB_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
AUTO_CREATE_TABLES=true

# Writable runtime paths inside the container/volume
HIVEMIND_DATA_DIR=/var/lib/hivemind
HIVEMIND_UPLOADS_DIR=/var/lib/hivemind/uploads

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------

# Include Tauri origins plus your AWS/API hostname.
CORS_ORIGINS=tauri://localhost,https://tauri.localhost,https://api.yourdomain.com

# -----------------------------------------------------------------------------
# RAG (Retrieval-Augmented Generation) Settings
# -----------------------------------------------------------------------------

EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_MIN_TOKENS=500
RAG_CHUNK_MAX_TOKENS=800
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.0

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------

# If S3 is configured, uploads are written there. Otherwise they stay on the
# EC2 volume mounted at HIVEMIND_UPLOADS_DIR.
AWS_REGION=us-east-1
S3_BUCKET=

# Use access_key and secret_key, or aws_access_key_id and
# aws_secret_access_key. On EC2 with IAM role, omit S3_CREDENTIALS.
# S3_CREDENTIALS={"access_key":"AKIA...","secret_key":"...","region":"us-east-1"}
S3_CREDENTIALS=

