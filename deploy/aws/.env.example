# -----------------------------------------------------------------------------
# AWS / EC2 deployment settings for the Docker Compose stack
# Copy this file to .env.aws before running deploy/aws/deploy.sh
# -----------------------------------------------------------------------------

# Public port exposed by the FastAPI server on the EC2 instance
HIVEMIND_PUBLIC_PORT=8000

# -----------------------------------------------------------------------------
# RDS mode (recommended): Amazon RDS PostgreSQL connection
# -----------------------------------------------------------------------------
# Set DATABASE_URL to your RDS endpoint. Include sslmode=require for RDS.
# Format: postgresql+psycopg2://USER:PASSWORD@RDS_HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql+psycopg2://hivemind:YOUR_PASSWORD@your-rds-instance.region.rds.amazonaws.com:5432/hivemind?sslmode=require

# -----------------------------------------------------------------------------
# Hivemind application settings
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
AUTO_CREATE_TABLES=True
JWT_SECRET=replace-with-a-long-random-secret
ANTHROPIC_API_KEY=

# Cleared usernames for Admin login (comma-separated)
CLEARED_USERNAMES=admin,developer

# Desktop app and browser origins allowed to call the API (Admin + Client use tauri://localhost).
# Include your EC2 base URL so the API can be called from browsers if needed.
CORS_ORIGINS=tauri://localhost,https://tauri.localhost,http://localhost:5173,http://127.0.0.1:5173,http://13.63.209.56:8000,https://api.yourdomain.com

# -----------------------------------------------------------------------------
# Optional S3-backed document storage
# -----------------------------------------------------------------------------
# If S3_BUCKET is blank, uploads are stored on the EC2 instance volume.
# If S3_BUCKET is set, the app can use the EC2 instance IAM role automatically.
AWS_REGION=us-east-1
S3_BUCKET=

# Optional explicit credentials if not using an EC2 IAM role.
# Use keys: access_key, secret_key, region (region can also come from AWS_REGION).
# S3_CREDENTIALS={"access_key":"AKIA...","secret_key":"...","region":"us-east-1"}
S3_CREDENTIALS=
