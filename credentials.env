# =============================================================================
# HIVEMIND — DEFAULT LOGIN CREDENTIALS
# =============================================================================
# Share this file with team members who need access to the Hivemind platform.
# These are the default accounts created on the first server startup.
#
# For production deployments, change these passwords by setting
# DEFAULT_ADMIN_PASSWORD and DEFAULT_CLIENT_PASSWORD in the server's .env
# file BEFORE the first startup. After that, passwords are stored as bcrypt
# hashes in the database and cannot be recovered from these env vars.
# =============================================================================

# ---- Admin App (Hivemind Admin) ----
# Full access to agent configuration, knowledge bases, simulations, settings.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=hivemind-admin-2024

# ---- Client App (Hivemind Client) ----
# Access to run analyses, manage client data, and view results.
CLIENT_USERNAME=client
CLIENT_PASSWORD=hivemind-client-2024
